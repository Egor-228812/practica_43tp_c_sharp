<Window x:Class="Petrov_Tema_12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система бронирования отеля" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="roomsGrid" Grid.Column="0" AutoGenerateColumns="True" Margin="5"/>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <StackPanel Grid.Column="2" Margin="5">
            <GroupBox Header="Бронирование" Margin="0,0,0,10">
                <StackPanel>
                    <Label Content="ФИО"/>
                    <TextBox x:Name="nameBox" Margin="0,5"/>
                    <Label Content="Дата заезда"/>
                    <DatePicker x:Name="checkInPicker" Margin="0,5"/>
                    <Label Content="Дата выезда"/>
                    <DatePicker x:Name="checkOutPicker" Margin="0,5"/>
                    <Button x:Name="bookButton" Content="Забронировать" Margin="0,10,0,0" Padding="5"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Список бронирований" Margin="0,10,0,0">
                <DataGrid x:Name="bookingsGrid" AutoGenerateColumns="True" Height="200"/>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>