<Window x:Class="Petrov_Tema_12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система бронирования отеля" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddBookingCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditBookingCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding CancelBookingCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Номера">
                <MenuItem Header="Список номеров" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Обновить статус" Click="RefreshRooms_Click"/>
            </MenuItem>
            <MenuItem Header="_Бронирование">
                <MenuItem Header="_Добавить" Command="{Binding AddBookingCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Редактировать" Command="{Binding EditBookingCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="_Отменить" Command="{Binding CancelBookingCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- пвель инструментов -->
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddBookingCommand}" Content="Забронировать номер" ToolTip="Ctrl+N"/>
            <Button Command="{Binding EditBookingCommand}" Content="Редактировать бронь" ToolTip="Ctrl+E"/>
            <Button Command="{Binding CancelBookingCommand}" Content="Отменить бронь" ToolTip="Del"/>
        </ToolBar>

        <!-- основная област -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- список номеров -->
            <DataGrid x:Name="roomsGrid" Grid.Column="0" AutoGenerateColumns="True" IsReadOnly="True"
                      SelectionMode="Single" Margin="0,0,5,0"/>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- правая панель -->
            <StackPanel Grid.Column="2" Margin="5,0,0,0">
                <GroupBox Header="Бронирование" Margin="0,0,0,10">
                    <StackPanel>
                        <Label Content="ФИО"/>
                        <TextBox x:Name="nameBox" Margin="0,5"/>
                        <Label Content="Дата заезда"/>
                        <DatePicker x:Name="checkInPicker" Margin="0,5"/>
                        <Label Content="Дата выезда"/>
                        <DatePicker x:Name="checkOutPicker" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Список бронирований" Margin="0,10,0,0">
                    <DataGrid x:Name="bookingsGrid" AutoGenerateColumns="True" IsReadOnly="True"
                              SelectionMode="Single" Height="200" SelectionChanged="BookingsGrid_SelectionChanged"/>
                </GroupBox>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>